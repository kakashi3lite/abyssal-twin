{
  "name": "abyssal-mission-control",
  "version": "2.0.0",
  "description": "Enterprise AUV Fleet Command Center - Asset Assurance Intelligence Platform",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "build:prod": "tsc && vite build --mode production",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "lint": "tsc --noEmit && eslint src --ext .ts,.tsx",
    "test": "vitest",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "chart.js": "^4.4.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^3.0.6",
    "framer-motion": "^12.35.0",
    "mapbox-gl": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-map-gl": "^7.1.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/mapbox-gl": "^3.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "auv",
    "underwater-robotics",
    "digital-twin",
    "fleet-management",
    "asset-assurance",
    "predictive-safety",
    "cloudflare",
    "websocket",
    "real-time",
    "enterprise"
  ],
  "author": "Abyssal Twin Inc.",
  "license": "Commercial",
  "repository": {
    "type": "git",
    "url": "https://github.com/kakashi3lite/abyssal-twin.git",
    "directory": "mission-control"
  }
}
