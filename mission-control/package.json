{
  "name": "abyssal-mission-control",
  "version": "1.0.0",
  "description": "Real-time AUV Fleet Dashboard - Market Ready Mission Control",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "build:prod": "tsc && vite build --mode production",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^3.0.6"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wrangler": "^3.22.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "auv",
    "underwater-robotics",
    "digital-twin",
    "fleet-management",
    "cloudflare",
    "websocket",
    "real-time"
  ],
  "author": "Abyssal Twin Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kakashi3lite/abyssal-twin.git",
    "directory": "mission-control"
  }
}
