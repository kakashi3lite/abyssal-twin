# IoRT-DT Environment Configuration
# Copy to .env and edit values before running docker compose.

# ─── Fleet ──────────────────────────────────────────────────────────────────
# Number of AUVs in simulation (1-8)
IORT_DT_AUV_COUNT=2

# ─── Federation ─────────────────────────────────────────────────────────────
# Gossip interval in milliseconds (lower = faster convergence, more bandwidth)
GOSSIP_INTERVAL_MS=500
# Seconds before a peer is considered partitioned
PARTITION_TIMEOUT_S=30

# ─── ROS 2 ──────────────────────────────────────────────────────────────────
ROS_DOMAIN_ID=42
RMW_IMPLEMENTATION=rmw_zenoh_cpp

# ─── Observability ──────────────────────────────────────────────────────────
# Grafana admin password (change in production)
GRAFANA_ADMIN_PASSWORD=admin

# ─── Logging ────────────────────────────────────────────────────────────────
# Rust log level: trace, debug, info, warn, error
RUST_LOG=iort_dt_federation=info
